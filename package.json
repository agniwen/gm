{
  "name": "genmsg",
  "version": "0.3.1",
  "module": "index.ts",
  "bin": {
    "gm": "./dist/gm.js",
    "gmp": "./dist/gmp.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "gm": "bun ./index.ts",
    "gmp": "bun ./index-gmp.ts",
    "build": "bun build ./index.ts --target=node --packages=external --outfile ./dist/gm.js && bun build ./index-gmp.ts --target=node --packages=external --outfile ./dist/gmp.js && chmod +x ./dist/gm.js ./dist/gmp.js",
    "prepublishOnly": "bun run build"
  },
  "type": "module",
  "devDependencies": {
    "@types/bun": "^1.3.12"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@commitlint/config-conventional": "^20.4.2",
    "@commitlint/lint": "^20.4.2",
    "@opentui/core": "^0.1.83",
    "cac": "^7.0.0",
    "empathic": "^2.0.0",
    "openai": "^6.24.0"
  }
}
